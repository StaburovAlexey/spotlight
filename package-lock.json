{
  "name": "music-app",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "music-app",
      "version": "0.1.0",
      "workspaces": [
        "apps/*",
        "packages/*"
      ]
    },
    "apps/api": {
      "name": "@music-app/api",
      "version": "0.1.0",
      "dependencies": {
        "@music-app/shared": "0.1.0"
      },
      "devDependencies": {}
    },
    "apps/web": {
      "name": "@music-app/web",
      "version": "0.1.0",
      "dependencies": {
        "@music-app/shared": "0.1.0"
      },
      "devDependencies": {}
    },
    "node_modules/@music-app/api": {
      "resolved": "apps/api",
      "link": true
    },
    "node_modules/@music-app/shared": {
      "resolved": "packages/shared",
      "link": true
    },
    "node_modules/@music-app/web": {
      "resolved": "apps/web",
      "link": true
    },
    "packages/shared": {
      "name": "@music-app/shared",
      "version": "0.1.0"
    }
  }
}
